# Copy to .env and fill in. .env is gitignored.
# Loaded automatically at CLI startup (src/hypemm/cli.py:main).

# --- Live trading auth (required for `hypemm run --live`) ---

# Option A: Foundry keystore (recommended — matches the rpo-{nb} convention).
# HYPERLIQUID_KEYSTORE accepts either a short name (looked up under
# ~/.foundry/keystores/) or an absolute path.
HYPERLIQUID_KEYSTORE=rpo-81
# Either HYPERLIQUID_KEYSTORE_PWD or RPO_KEYSTORE_PWD works.
RPO_KEYSTORE_PWD=

# Option B: raw private key (takes precedence over keystore if both are set).
# HYPERLIQUID_PRIVATE_KEY=0x...

# Optional. If unset, defaults to the signer's address (i.e. the keystore IS
# the trading account, no separate API wallet on behalf of a vault).
# HYPERLIQUID_ACCOUNT=0x...

# Optional. Defaults to mainnet; set to testnet for smoke-tests.
# HYPERLIQUID_API_URL=https://api.hyperliquid-testnet.xyz
